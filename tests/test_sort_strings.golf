package main

func Show(v slice[string]) {
	for i, s := range v {
		println(i, s)
	}
}

func Sort(a slice[string]) {
	n := len(a)
	for k := range n - 1 {
		println("-----------------------", k)
		for i := range n - 1 {
			j := i + 1
			if a[i] > a[j] {
				println("  swap", i, a[i], j, a[j])
				a[i], a[j] = a[j], a[i] // swap
				println("  becomes", i, a[i], j, a[j])
			}
		}
		Show(v)
	}
}

var arr [20]string
var v slice[string]

func main() {
	v.Base = word(&arr[2])
	v.Len = 14
	v.Cap = 14

	v[0] = "zero"
	v[1] = "one"
	v[2] = "two"
	v[3] = "three"
	v[4] = "four"
	v[5] = "five"
	v[6] = "six"
	v[7] = "seven"
	v[8] = "eight"
	v[9] = "nine"
	v[10] = "eighty"
	v[11] = "ninety"
	v[12] = "fourty"
	v[13] = "seventy"

	Sort(v)
}
