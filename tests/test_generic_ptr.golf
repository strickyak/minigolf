package main

type S struct { x word }
func fff() {}

func peek[T any](addr word) T {
	return *((*T)(addr))
}

func poke[T any](addr word, value T) {
	*((*T)(addr)) = value
}

func main() {
	var x word = 42
	var p *word = &x

	// peek with a pointer type argument: peek[*word]
	var pp *word = peek[*word](word(&p))
	println(*pp)

	// peek with simple types (regression check)
	println(peek[word](word(&x)))

	var b byte = 0
	poke[byte](word(&b), 111)
	println(b)

	var w word = 0
	poke[word](word(&w), 222)
	println(w)

	var s S
	var sp *S = &s
	poke[*S](word(&sp), nil)
	if sp == nil {
		println(333)
	}

	var fn func() = fff
	poke[func()](word(&fn), nil)
	if fn == nil {
		println(444)
	}
}
