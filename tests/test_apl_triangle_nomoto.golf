package _

import "apl"

func main() {
	apl.PrintThing(apl.TestEval(
		"<> triangle N { ( N < 2 ? N : N + triangle N - 1 ) } ; triangle 10"))

	apl.PrintThing(apl.TestEval(
		"<> fib N { ( N < 2 ? N : (fib N - 2) + fib N - 1 ) } ; fib 5"))

	apl.PrintThing(apl.TestEval(
		"<> triangle N ; M { M = N - 1 ; ( N < 2 ? N : N + triangle M ) } ; triangle 10"))

	apl.PrintThing(apl.TestEval(
		"<> A <<< B { A < B - 5 } ; ( iota 10 ) <<< 10 "))
}
