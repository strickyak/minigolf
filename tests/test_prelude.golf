package main

import "prelude"

var m1 memslice
var m2 memslice

var b1 slice[byte]
var w1 slice[word]
var i1 slice[int]

var ram [1500]byte

func main() {
    m1.Base = word(&ram)
    m1.Cap = 200
    m1.Len = 100

    println(m1.Get(10))
    m1.Put(10, 42)
    println(m1.Get(10))

    m2 = m1

    println(m2.Get(10))
    m2.Put(10, 92)
    println(m2.Get(10))

    b1.guts = m1
    println(b1.Get(10))

    w1.guts.Base = word(&ram) + 500
    w1.guts.Cap = 10
    w1.guts.Len = 5

    println(w1.Get(3))
    w1.Put(3, 88)
    println(w1.Get(3))
}
