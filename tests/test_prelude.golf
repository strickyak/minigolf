package main

var b1 slice[byte]
var b2 slice[byte]
var w1 slice[word]
var i1 slice[int]

var ram [1500]byte

func main() {
	b1.Base = word(&ram)
	b1.Cap = 200
	b1.Len = 100

	println(b1.Get(10))
	b1.Put(10, 42)
	println(b1.Get(10))

	b2 = b1

	println(b2.Get(10))
	b2.Put(10, 92)
	println(b2.Get(10))

	println(b1.Get(10))

	w1.Base = word(&ram) + 500
	w1.Cap = 10
	w1.Len = 5

	println(w1.Get(3))
	w1.Put(3, 88)
	println(w1.Get(3))
}
