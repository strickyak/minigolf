package pre2

func mul(a word, b word) word {
	return mul_word(a, b)
}

func div(dividend word, divisor word) word {
	return div_word(dividend, divisor)
}

func printany2(x any) {
	ch := peekb(x.TypeStr)
	if ch == 'b' {
		// byte
		println("b=", peek[byte](x.BaseAddr))
	} else if ch == 'w' {
		// word
		println("w=", peek[word](x.BaseAddr))
	} else if ch == 's' {
		// string
		s0 := peek[string](x.BaseAddr) // not NUL-terminated
		s1 := strdup(s0)               // NUL-terminated
		println("s=", s1)
		strfree(s1)
	} else {
		println("?", ch, "?")
	}
}

////////////////////////////////////////////////////

func main() {
	s := "one two three"
	printany2(s[0:3])
	printany2(s[4:7])
	printany2(s[8:13])
}
