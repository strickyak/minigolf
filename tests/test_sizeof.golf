package main

type Foo[T any] struct {
    next    *T
    last    *T
}
    
type Bar struct {
    foo *Foo[int]
    b byte
}


func main() {
	var a word = sizeof[byte]()
	var b word = sizeof[word]()
	var c word = sizeof[[3]byte]()
	var d byte = sizeof[Foo[byte]]()
	var e byte = sizeof[Bar]()

	if a == 1 { println("ok") } else { println(a) }
	if b == 2 || b == 8 { println("ok") } else { println(b) }
	if c == 3 { println("ok") } else { println(c) }
	if d == 4 || d == 16 { println("ok") } else { println(d) }
	if e == 3 || e == 12 || e == 16 { println("ok") } else { println(e) }
}
