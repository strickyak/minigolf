package main

func main() {
	println("17 * 17 is", 17*17)
	println("505 * 120 is", 505*120)
	println("50000 / 23 is", 50000/23)
	println("50000 mod 23 is", 50000%23)

	println("123 & 45 is", 123&45)
	println("123 | 45 is", 123|45)
	println("123 ^ 45 is", 123^45)
	println("123 &^ 45 is", 123&^45)

	println("45678 & 12345 is", 45678&12345)
	println("45678 | 12345 is", 45678|12345)
	println("45678 ^ 12345 is", 45678^12345)
	println("45678 &^ 12345 is", 45678&^12345)
}
