package main

func main() {
	var a byte = 250
	var b byte = 10
	var c byte = a + b
	if c == 4 {
		println(1)
	} else {
		println(0)
	}
	if a > b {
		println(1)
	} else {
		println(0)
	}

	var x word = 65530
	var y word = 10
	var z word = x + y
	if z == 65540 {
		println(1)
	} else {
		if z == 4 {
			println(1)
		} else {
			println(0)
		}
	}
	if x > y {
		println(1)
	} else {
		println(0)
	}

	var m int = 0 - 100
	var n int = 0 - 200
	if m == 0 - 100 {
		println(1)
	} else {
		if m == 65436 {
			println(1)
		} else {
			println(0)
		}
	}
	if m > n {
		println(1)
	} else {
		println(0)
	}
	if m < n {
		println(0)
	} else {
		println(1)
	}

	var u uint = 65500
	var v uint = 100
	var w uint = u + v
	if w == 65600 {
		println(1)
	} else {
		if w == 64 {
			println(1)
		} else {
			println(0)
		}
	}
}
