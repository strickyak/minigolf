package main

type Link[T any] struct {
	Value T
	Next  *Link[T]
}

var globalA Link[byte]
var globalB Link[byte]

func main() {
	globalA.Value = 42
	
	globalB.Value = 100
	globalA.Next = &globalB
	
	println(globalA.Value)
	var ptr *Link[byte] = globalA.Next
	println(ptr.Value)

	println(First[byte](&globalA))
	println(First(&globalB))

	println(Draw[byte, int](6, 7))
	println(Draw(6, 7))
}

func First[T any](root *Link[T]) T {
	return root.Value
}

func Draw[A any, B any](a A, b B) int {
	return 100 // Returning a simple integer to test parameter substitution
}
