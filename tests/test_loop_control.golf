package main

func main() {
	println("test for break")
	for i := 0; i < 10; i++ {
		if i == 5 {
			break
		}
		println(i)
	}

	println("test for continue")
	for i := 0; i < 5; i++ {
		if i == 2 {
			continue
		}
		println(i)
	}

	println("test for range continue")
	for i := range 5 {
		if i == 1 {
			continue
		}
		if i == 4 {
			break
		}
		println(i)
	}

	println("test for simple continue")
	i := 0
	for i < 3 {
		i++
		if i == 2 {
			continue
		}
		println(i)
	}

	println("done")
}
