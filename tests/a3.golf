package main

import "pre2"

const N = 8

var pointers [N]*byte

func main() {
	println("start")

	for k := range N {
		println("round", k)

		for i := range N {
			pointers[i] := pre2.malloc(10 * i)
			// println(word(pointers[i]), "malloc", i)
		}
		for i := range N {
			// println(word(pointers[i]), "free", i)
			pre2.free(pointers[i])
		}
	}

	println("finish")
}
