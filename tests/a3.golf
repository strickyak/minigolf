package main

const N = 8

var pointers [N]*byte

func main() {
	println("start")

	for k := range N {
		println("round", k)

		for i := range N {
			pointers[i] = malloc(10 * i)
			// println(word(pointers[i]), "malloc", i)
		}
		for i := range N {
			// println(word(pointers[i]), "free", i)
			free(pointers[i])
		}
	}

	println("finish")
}
