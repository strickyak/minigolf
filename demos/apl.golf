package _

// Hint: 2 == "+" reduce 0 == "mod" table 1 + iota 10

import "smap"
import "sort"

// ===== External I/O =====

// minigolf:linkage("getchar")
func getchar() int

// ===== Constants =====

const REPL = 0 // Set to 1 for interactive mode: -D=main.REPL=1

// Token types
const TokNum = 1

func CmpString(a *string, b *string) int {
	if *a < *b {
		return -1
	}
	if *a > *b {
		return 1
	}
	return 0
}

const TokVar = 2
const TokFunc = 3
const TokArrow = 4
const TokLParen = 5
const TokRParen = 6
const TokSemi = 7
const TokDel = 8
const TokLBrace = 9
const TokRBrace = 10
const TokQuestion = 11
const TokColon = 12
const TokLBracket = 13
const TokRBracket = 14
const TokStrLit = 15 // double-quoted. Becomes vector of ints.

// ===== Function Type Aliases =====

type MonadicFn func(*Thing) *Thing
type DyadicFn func(*Thing, *Thing) *Thing
type ArithOp func(int, int) int

// ===== I/O Utilities (putchar/getchar only) =====

func PutInt(n int) {
	if n < 0 {
		putchar('-')
		n = 0 - n
	}
	if n >= 10 {
		PutInt(n / 10)
	}
	putchar(byte(n%10) + '0')
}

func IntWidth(n int) word {
	w := word(1)
	if n < 0 {
		w++
		n = 0 - n
	}
	for n >= 10 {
		n = n / 10
		w++
	}
	return w
}

func PutIntPadded(n int, width word) {
	w := IntWidth(n)
	for w < width {
		putchar(' ')
		w++
	}
	PutInt(n)
}

func PutStr(s *byte) {
	for *s != 0 {
		putchar(*s)
		s = (*byte)(word(s) + 1)
	}
}

// ===== Line Buffer =====

var LineBuf [256]byte
var LineLen word

func ReadLine() byte {
	LineLen = 0
	for {
		c := getchar()
		if c < 0 {
			if LineLen > 0 {
				return 1
			}
			return 0
		}
		if c == '\n' {
			return 1
		}
		if c == '\r' {
			continue
		}
		if LineLen < 255 {
			LineBuf[LineLen] = byte(c)
			LineLen++
		}
	}
	return 0
}

// ===== Thing: APL Value =====
//
// An APL value is a multi-dimensional array of ints.
// Scalar: Dimensions is empty, Values has 1 element.
// Vector: Dimensions=[n], Values has n elements.
// Matrix: Dimensions=[r,c], Values has r*c elements (row-major).
//
// Int values are stored by casting: int -> word -> *Thing.

type Thing struct {
	Values     slice[*Thing]
	Dimensions slice[word]
}

func (t *Thing) destructor() {
	free((*byte)(t.Values.Base))
	free((*byte)(t.Dimensions.Base))
}

func NewThing() *Thing {
	return (*Thing)(zalloc(sizeof[Thing]()))
}

func FreeThing(t *Thing) {
	if word(t) != 0 {
		free((*byte)(t.Values.Base))
		free((*byte)(t.Dimensions.Base))
		free((*byte)(word(t)))
	}
}

// Store an int inside a *Thing pointer slot
func IntToPtr(n int) *Thing {
	return (*Thing)(word(n))
}

// Retrieve the int from a *Thing pointer slot
func PtrToInt(p *Thing) int {
	return int(word(p))
}

func MakeScalar(n int) *Thing {
	t := NewThing()
	t.Values.Append(IntToPtr(n))
	return t
}

// ===== Global smap-based storage =====

var Strings smap.InternTable
var Vars smap.Imap[*Thing]
var MonadicOps smap.Imap[word]
var DyadicOps smap.Imap[word]

type UserFunction struct {
	LhsName   string
	RhsName   string
	Locals    slice[string]
	NumTokens word
	TokKinds  slice[byte]
	TokVals   slice[word]
	TokNames  slice[string]
}

var UserMonadicOps smap.Imap[*UserFunction]
var UserDyadicOps smap.Imap[*UserFunction]

// ===== Helper: build string from LineBuf range =====

func BufStr(start word, length word) string {
	var s string
	s.Base = word(&LineBuf[start])
	s.Len = length
	s.Cap = length
	return s
}

// ===== Tokenizer =====

var TokKinds [100]byte
var TokVals [100]word
var TokNames [100]string
var NumTokens word

func IsSymbolChar(c byte) byte {
	if c == '(' || c == ')' || c == '[' || c == ']' || c == '{' || c == '}' || c == '"' {
		return 0
	}
	if c >= '!' && c <= '/' {
		return 1 // !#$%&'*+,-./ (but grouping filtered above)
	}
	if c >= ':' && c <= '@' && c != ';' && c != '?' && c != ':' {
		return 1 // <=@
	}
	if c == '\\' || c == '^' || c == '`' || c == '|' || c == '~' {
		return 1
	}
	return 0
}

func Tokenize() {
	NumTokens = 0
	pos := word(0)
	for pos < LineLen {
		// Skip whitespace
		for pos < LineLen {
			ch := LineBuf[pos]
			if ch != ' ' && ch != '\t' {
				break
			}
			pos++
		}
		if pos >= LineLen {
			break
		}

		c := LineBuf[pos]

		// String literal (e.g. "Hello") becomes vector of ASCII values (e.g. 72 101 108 108 111)
		if c == '"' {
			pos++ // consume the opening "
			// yak
			var s string
			for pos < LineLen && LineBuf[pos] != '"' {
				s.Append(LineBuf[pos])
				pos++
			}
			s.Append(0)
			pos++ // consume the closing "
			TokKinds[NumTokens] = TokStrLit
			TokVals[NumTokens] = word(s.Base) // Take guts from string
			NumTokens++
			continue
		}

		// TokDel '<>'
		if c == '<' && pos+1 < LineLen && LineBuf[pos+1] == '>' {
			TokKinds[NumTokens] = TokDel
			TokVals[NumTokens] = 0
			NumTokens++
			pos = pos + 2
			continue
		}

		// Assignment arrow '<-' or standalone '='
		if c == '<' && pos+1 < LineLen && LineBuf[pos+1] == '-' {
			TokKinds[NumTokens] = TokArrow
			TokVals[NumTokens] = 0
			NumTokens++
			pos = pos + 2
			continue
		}
		if c == '=' {
			// Ensure it's not followed by another symbol character
			isStandalone := byte(1)
			if pos+1 < LineLen && IsSymbolChar(LineBuf[pos+1]) != 0 {
				isStandalone = 0
			}
			if isStandalone != 0 {
				TokKinds[NumTokens] = TokArrow
				TokVals[NumTokens] = 0
				NumTokens++
				pos++
				continue
			}
		}

		// Number (possibly negative: '-' followed by digit)
		isNum := byte(0)
		if c >= '0' && c <= '9' {
			isNum = 1
		}
		if c == '-' && pos+1 < LineLen && LineBuf[pos+1] >= '0' && LineBuf[pos+1] <= '9' {
			isNum = 1
		}
		if isNum != 0 {
			sign := int(1)
			if c == '-' {
				sign = 0 - 1
				pos++
			}
			n := int(0)
			for pos < LineLen && LineBuf[pos] >= '0' && LineBuf[pos] <= '9' {
				n = n*10 + int(word(LineBuf[pos])) - int(word('0'))
				pos++
			}
			TokKinds[NumTokens] = TokNum
			TokVals[NumTokens] = word(n * sign)
			NumTokens++
			continue
		}

		// Uppercase name (variable)
		if c >= 'A' && c <= 'Z' {
			start := pos
			for pos < LineLen {
				ch := LineBuf[pos]
				ok := byte(0)
				if ch >= 'A' && ch <= 'Z' {
					ok = 1
				}
				if ch >= 'a' && ch <= 'z' {
					ok = 1
				}
				if ch >= '0' && ch <= '9' {
					ok = 1
				}
				if ch == '_' {
					ok = 1
				}
				if ok == 0 {
					break
				}
				pos++
			}
			length := pos - start
			name := Strings.Intern(BufStr(start, length))
			TokKinds[NumTokens] = TokVar
			TokNames[NumTokens] = name
			NumTokens++
			continue
		}

		// Lowercase name (function/operator)
		if c >= 'a' && c <= 'z' {
			start := pos
			for pos < LineLen {
				ch := LineBuf[pos]
				ok := byte(0)
				if ch >= 'a' && ch <= 'z' {
					ok = 1
				}
				if ch >= '0' && ch <= '9' {
					ok = 1
				}
				if ch == '_' {
					ok = 1
				}
				if ok == 0 {
					break
				}
				pos++
			}
			length := pos - start
			name := Strings.Intern(BufStr(start, length))
			TokKinds[NumTokens] = TokFunc
			TokNames[NumTokens] = name
			NumTokens++
			continue
		}

		// Parentheses
		if c == '(' {
			TokKinds[NumTokens] = TokLParen
			TokVals[NumTokens] = 0
			NumTokens++
			pos++
			continue
		}
		if c == ')' {
			TokKinds[NumTokens] = TokRParen
			TokVals[NumTokens] = 0
			NumTokens++
			pos++
			continue
		}
		if c == '{' {
			TokKinds[NumTokens] = TokLBrace
			TokVals[NumTokens] = 0
			NumTokens++
			pos++
			continue
		}
		if c == '}' {
			TokKinds[NumTokens] = TokRBrace
			TokVals[NumTokens] = 0
			NumTokens++
			pos++
			continue
		}
		if c == '[' {
			TokKinds[NumTokens] = TokLBracket
			TokVals[NumTokens] = 0
			NumTokens++
			pos++
			continue
		}
		if c == ']' {
			TokKinds[NumTokens] = TokRBracket
			TokVals[NumTokens] = 0
			NumTokens++
			pos++
			continue
		}
		if c == '?' {
			TokKinds[NumTokens] = TokQuestion
			TokVals[NumTokens] = 0
			NumTokens++
			pos++
			continue
		}
		if c == ':' {
			TokKinds[NumTokens] = TokColon
			TokVals[NumTokens] = 0
			NumTokens++
			pos++
			continue
		}

		// Symbol operator (one or more special characters, not grouping)
		if IsSymbolChar(c) != 0 {
			start := pos
			for pos < LineLen && IsSymbolChar(LineBuf[pos]) != 0 {
				pos++
			}
			length := pos - start
			name := Strings.Intern(BufStr(start, length))
			TokKinds[NumTokens] = TokFunc
			TokNames[NumTokens] = name
			NumTokens++
			continue
		}

		// Semicolon (statement separator)
		if c == ';' {
			TokKinds[NumTokens] = TokSemi
			TokVals[NumTokens] = 0
			NumTokens++
			pos++
			continue
		}

		// Unknown non-whitespace character
		panic("unexpected character in input")
	}
}

// ===== Execution & Skipping Helpers =====

func EvalStatementsUntil(stop1 byte, stop2 byte) *Thing {
	var result *Thing
	for EvalPos < NumTokens {
		WasAssign = 0
		k := TokKinds[EvalPos]
		if k == stop1 || k == stop2 {
			break
		}
		result = Eval()
		if EvalPos < NumTokens {
			k2 := TokKinds[EvalPos]
			if k2 == stop1 || k2 == stop2 {
				break
			}
			if k2 == TokSemi {
				EvalPos++
			} else {
				panic("unexpected token after expression")
			}
		}
	}
	return result
}

func SkipTokensUntil(stop1 byte, stop2 byte) byte {
	var stack [100]byte
	sp := word(0)

	for EvalPos < NumTokens {
		k := TokKinds[EvalPos]
		if k == TokLParen || k == TokLBracket || k == TokLBrace {
			stack[sp] = k
			sp++
		} else if k == TokRParen || k == TokRBracket || k == TokRBrace {
			if sp == 0 {
				if stop1 == k || stop2 == k {
					return k
				}
				panic("unmatched closing parenthesis/bracket/brace")
			}
			sp--
			top := stack[sp]
			if (k == TokRParen && top != TokLParen) ||
				(k == TokRBracket && top != TokLBracket) ||
				(k == TokRBrace && top != TokLBrace) {
				panic("mismatched closing grouping symbol")
			}
		} else if sp == 0 && (k == stop1 || k == stop2) {
			return k
		}
		EvalPos++
	}
	panic("unexpected end of input while skipping")
}

// ===== Evaluator =====
//
// APL evaluates right-to-left. We scan left-to-right but recurse
// for right arguments, which gives right-to-left semantics:
//   3 3 rho iota 9
// => strand [3,3], then dyadic rho, then recurse:
//     => monadic iota, then recurse:
//         => strand [9] => scalar 9
//     => iota(9) => [0..8]
// => [3,3] rho [0..8] => 3x3 matrix

var EvalPos word
var WasAssign byte

func Eval() *Thing {
	if EvalPos >= NumTokens {
		panic("unexpected end of expression")
	}

	kind := TokKinds[EvalPos]

	// Function Definition
	if kind == TokDel {
		EvalPos++
		if EvalPos >= NumTokens {
			panic("expected function or variable name")
		}

		isDyadic := byte(0)
		var lhsName string
		if TokKinds[EvalPos] == TokVar {
			isDyadic = 1
			lhsName = TokNames[EvalPos]
			EvalPos++
		}

		if EvalPos >= NumTokens || TokKinds[EvalPos] != TokFunc {
			panic("expected function name")
		}
		name := TokNames[EvalPos]
		EvalPos++

		if EvalPos >= NumTokens || TokKinds[EvalPos] != TokVar {
			panic("expected argument name")
		}
		rhsName := TokNames[EvalPos]
		EvalPos++

		var locals slice[string]

		// Parse optional locals: ; localName
		for EvalPos < NumTokens && TokKinds[EvalPos] == TokSemi {
			EvalPos++ // skip ;
			if EvalPos >= NumTokens || TokKinds[EvalPos] != TokVar {
				panic("expected local variable name after ;")
			}
			if locals.Len >= 20 {
				panic("maximum 20 local variables exceeded")
			}
			locals.Append(TokNames[EvalPos])
			EvalPos++
		}

		if EvalPos >= NumTokens || TokKinds[EvalPos] != TokLBrace {
			panic("expected {")
		}
		EvalPos++

		var tKinds slice[byte]
		var tVals slice[word]
		var tNames slice[string]
		numT := word(0)

		// Copy tokens until TokRBrace
		for EvalPos < NumTokens && TokKinds[EvalPos] != TokRBrace {
			tKinds.Append(TokKinds[EvalPos])
			tVals.Append(TokVals[EvalPos])
			tNames.Append(TokNames[EvalPos])
			numT++
			EvalPos++
		}
		if EvalPos >= NumTokens || TokKinds[EvalPos] != TokRBrace {
			panic("missing }")
		}
		EvalPos++ // skip }

		u := (*UserFunction)(zalloc(sizeof[UserFunction]()))
		u.LhsName = lhsName
		u.RhsName = rhsName
		u.Locals = locals
		u.NumTokens = numT
		u.TokKinds = tKinds
		u.TokVals = tVals
		u.TokNames = tNames

		if isDyadic != 0 {
			UserDyadicOps.Insert(name, u)
		} else {
			UserMonadicOps.Insert(name, u)
		}
		WasAssign = 1 // to prevent printing
		return (*Thing)(0)
	}

	// Monadic function application
	if kind == TokFunc {
		name := TokNames[EvalPos]
		EvalPos++
		right := Eval()
		if word(right) == 0 {
			panic("nil argument to monadic")
		}

		u, uok := UserMonadicOps.Lookup(name)
		if uok != 0 {
			return EvalUser(u, (*Thing)(0), right)
		}

		fw, ok := MonadicOps.Lookup(name)
		if ok == 0 {
			panic("unknown monadic function")
		}
		fn := MonadicFn(fw)
		return fn(right)
	}

	// Primary value: number strand or variable
	var val *Thing

	if kind == TokStrLit {
		// yak
		val = StrLitToThing()
		EvalPos++
	} else if kind == TokNum {
		val = ParseStrand()
	} else if kind == TokVar {
		name := TokNames[EvalPos]
		EvalPos++

		// Assignment: Name <- expr
		if EvalPos < NumTokens && TokKinds[EvalPos] == TokArrow {
			EvalPos++ // skip '<-'
			right := Eval()
			Vars.Insert(name, right)
			WasAssign = 1
			return right
		}

		// Variable lookup
		var ok byte
		val, ok = Vars.Lookup(name)
		if ok == 0 {
			panic("undefined variable")
		}
		if word(val) == 0 {
			panic("undefined variable")
		}
	} else if kind == TokLParen {
		EvalPos++ // skip '('
		val = EvalStatementsUntil(TokRParen, TokQuestion)
		if EvalPos >= NumTokens {
			panic("missing closing parenthesis or colon")
		}
		if TokKinds[EvalPos] == TokRParen {
			EvalPos++ // skip ')'
		} else if TokKinds[EvalPos] == TokQuestion {
			EvalPos++ // skip '?'
			if val.Dimensions.Len != 0 || val.Values.Len != 1 {
				panic("COND condition must be scalar int")
			}
			condVal := PtrToInt(val.Values.Get(0))
			if condVal != 0 {
				val = EvalStatementsUntil(TokColon, TokColon)
				if EvalPos >= NumTokens || TokKinds[EvalPos] != TokColon {
					panic("expected : after yes statements")
				}
				EvalPos++ // skip ':'
				SkipTokensUntil(TokRParen, TokRParen)
				EvalPos++ // skip ')'
			} else {
				SkipTokensUntil(TokColon, TokColon)
				if EvalPos >= NumTokens || TokKinds[EvalPos] != TokColon {
					panic("expected : after yes statements")
				}
				EvalPos++ // skip ':'
				val = EvalStatementsUntil(TokRParen, TokRParen)
				if EvalPos >= NumTokens || TokKinds[EvalPos] != TokRParen {
					panic("expected ) after no statements")
				}
				EvalPos++ // skip ')'
			}
		}
	} else {
		panic("unexpected token")
	}

	// Dyadic function: val func expr
	if EvalPos < NumTokens && TokKinds[EvalPos] == TokFunc {
		name := TokNames[EvalPos]
		EvalPos++
		right := Eval()
		if word(right) == 0 {
			panic("nil argument to dyadic")
		}
		u, uok := UserDyadicOps.Lookup(name)
		if uok != 0 {
			return EvalUser(u, val, right)
		}

		fw, ok := DyadicOps.Lookup(name)
		if ok == 0 {
			panic("not dyadic")
		}
		fn := DyadicFn(fw)
		return fn(val, right)
	}

	return val
}

func StrLitToThing() *Thing {
	// yak
	t := NewThing()
	p := (*byte)(TokVals[EvalPos])
	for *p {
		t.Values.Append(IntToPtr(int(*p)))
		p = (*byte)(word(p) + 1)
	}
	t.Dimensions.Append(t.Values.Len)
	return t
}

func ParseStrand() *Thing {
	// Collect consecutive number tokens into a vector (or scalar if just one)
	var nums [100]word
	count := word(0)
	for EvalPos < NumTokens && TokKinds[EvalPos] == TokNum {
		nums[count] = TokVals[EvalPos]
		count++
		EvalPos++
	}
	if count == 1 {
		return MakeScalar(int(nums[0]))
	}
	t := NewThing()
	t.Dimensions.Append(count)
	for i := range count {
		t.Values.Append(IntToPtr(int(nums[i])))
	}
	return t
}

// ===== APL Operations =====

// iota N => vector [0, 1, ..., N-1]  (0-based)
func DoIota(arg *Thing) *Thing {
	n := PtrToInt(arg.Values.Get(0))
	t := NewThing()
	t.Dimensions.Append(word(n))
	for i := range word(n) {
		t.Values.Append(IntToPtr(int(i)))
	}
	return t
}

// Monadic rho: return shape as a vector
func DoRhoMonadic(arg *Thing) *Thing {
	t := NewThing()
	nd := arg.Dimensions.Len
	if nd == 0 {
		// Scalar has empty shape
		t.Dimensions.Append(0)
		return t
	}
	t.Dimensions.Append(nd)
	for i := range nd {
		t.Values.Append(IntToPtr(int(arg.Dimensions.Get(i))))
	}
	return t
}

// Dyadic rho: reshape  (left=new shape, right=data, cycling as needed)
func DoRhoDyadic(left *Thing, right *Thing) *Thing {
	t := NewThing()
	totalElems := word(1)

	if left.Dimensions.Len == 0 {
		// Scalar left => 1-D reshape
		d := word(PtrToInt(left.Values.Get(0)))
		t.Dimensions.Append(d)
		totalElems = d
	} else {
		// Vector left => multi-D reshape
		for i := range left.Values.Len {
			d := word(PtrToInt(left.Values.Get(i)))
			t.Dimensions.Append(d)
			totalElems = totalElems * d
		}
	}

	rightLen := right.Values.Len
	if rightLen == 0 {
		rightLen = 1 // guard against modulo-by-zero
	}
	for i := range totalElems {
		idx := i % rightLen
		t.Values.Append(right.Values.Get(idx))
	}
	return t
}

func EvalUser(u *UserFunction, left *Thing, right *Thing) *Thing {
	// Save context
	oldNumTokens := NumTokens
	oldEvalPos := EvalPos
	var oldKinds [100]byte
	var oldVals [100]word
	var oldNames [100]string
	for i := word(0); i < NumTokens; i++ {
		oldKinds[i] = TokKinds[i]
		oldVals[i] = TokVals[i]
		oldNames[i] = TokNames[i]
	}
	oldRhs, rhsOk := Vars.Lookup(u.RhsName)

	var oldLhs *Thing
	var lhsOk byte
	if len(u.LhsName) > 0 {
		oldLhs, lhsOk = Vars.Lookup(u.LhsName)
	}

	var oldLocals [20]*Thing
	var localOks [20]byte
	numLocals := u.Locals.Len
	for i := word(0); i < numLocals; i++ {
		locName := u.Locals.Get(i)
		oldLocals[i], localOks[i] = Vars.Lookup(locName)
	}

	// Setup context
	NumTokens = u.NumTokens
	EvalPos = 0
	for i := word(0); i < NumTokens; i++ {
		TokKinds[i] = u.TokKinds.Get(i)
		TokVals[i] = u.TokVals.Get(i)
		TokNames[i] = u.TokNames.Get(i)
	}
	Vars.Insert(u.RhsName, right)
	if len(u.LhsName) > 0 {
		Vars.Insert(u.LhsName, left)
	}
	for i := word(0); i < numLocals; i++ {
		locName := u.Locals.Get(i)
		Vars.Insert(locName, (*Thing)(0))
	}

	defer func() {
		// Restore context
		NumTokens = oldNumTokens
		EvalPos = oldEvalPos
		for i := word(0); i < NumTokens; i++ {
			TokKinds[i] = oldKinds[i]
			TokVals[i] = oldVals[i]
			TokNames[i] = oldNames[i]
		}
		if rhsOk != 0 {
			Vars.Insert(u.RhsName, oldRhs)
		} else {
			Vars.Insert(u.RhsName, (*Thing)(0))
		}
		if len(u.LhsName) > 0 {
			if lhsOk != 0 {
				Vars.Insert(u.LhsName, oldLhs)
			} else {
				Vars.Insert(u.LhsName, (*Thing)(0))
			}
		}
		for i := word(0); i < numLocals; i++ {
			locName := u.Locals.Get(i)
			if localOks[i] != 0 {
				Vars.Insert(locName, oldLocals[i])
			} else {
				Vars.Insert(locName, (*Thing)(0))
			}
		}
	}()

	var res *Thing
	res = EvalStatementsUntil(0, 0)
	return res
}

// Monadic neg: negate all elements
func DoNeg(arg *Thing) *Thing {
	t := NewThing()
	for i := range arg.Dimensions.Len {
		t.Dimensions.Append(arg.Dimensions.Get(i))
	}
	for i := range arg.Values.Len {
		v := PtrToInt(arg.Values.Get(i))
		t.Values.Append(IntToPtr(0 - v))
	}
	return t
}

// ===== Element-wise Arithmetic Operations =====

func AddOp(a int, b int) int { return a + b }
func SubOp(a int, b int) int { return a - b }
func MulOp(a int, b int) int { return a * b }

func DivOp(a int, b int) int {
	if b == 0 {
		panic("division by zero")
	}
	return a / b
}

func ModOp(a int, b int) int {
	if b == 0 {
		panic("modulo by zero")
	}
	return a % b
}

func EqOp(a int, b int) int {
	if a == b {
		return 1
	}
	return 0
}
func NeqOp(a int, b int) int {
	if a != b {
		return 1
	}
	return 0
}
func LtOp(a int, b int) int {
	if a < b {
		return 1
	}
	return 0
}
func GtOp(a int, b int) int {
	if a > b {
		return 1
	}
	return 0
}
func LeOp(a int, b int) int {
	if a <= b {
		return 1
	}
	return 0
}
func GeOp(a int, b int) int {
	if a >= b {
		return 1
	}
	return 0
}

// ===== Dyadic Arithmetic with Scalar Extension =====

func DoArithDyadic(left *Thing, right *Thing, op ArithOp) *Thing {
	t := NewThing()
	leftLen := left.Values.Len
	rightLen := right.Values.Len

	// Both scalar
	if left.Dimensions.Len == 0 && right.Dimensions.Len == 0 {
		a := PtrToInt(left.Values.Get(0))
		b := PtrToInt(right.Values.Get(0))
		t.Values.Append(IntToPtr(op(a, b)))
		return t
	}

	// Copy shape from the array argument
	if left.Dimensions.Len > 0 {
		for i := range left.Dimensions.Len {
			t.Dimensions.Append(left.Dimensions.Get(i))
		}
	} else {
		for i := range right.Dimensions.Len {
			t.Dimensions.Append(right.Dimensions.Get(i))
		}
	}

	resultLen := leftLen
	if rightLen > resultLen {
		resultLen = rightLen
	}

	for i := range resultLen {
		li := i
		ri := i
		if leftLen == 1 {
			li = 0
		}
		if rightLen == 1 {
			ri = 0
		}
		a := PtrToInt(left.Values.Get(li))
		b := PtrToInt(right.Values.Get(ri))
		t.Values.Append(IntToPtr(op(a, b)))
	}
	return t
}

// Dyadic function wrappers matching DyadicFn signature
func DoAdd(left *Thing, right *Thing) *Thing   { return DoArithDyadic(left, right, AddOp) }
func DoSub(left *Thing, right *Thing) *Thing   { return DoArithDyadic(left, right, SubOp) }
func DoMulDy(left *Thing, right *Thing) *Thing { return DoArithDyadic(left, right, MulOp) }
func DoDivDy(left *Thing, right *Thing) *Thing { return DoArithDyadic(left, right, DivOp) }
func DoModDy(left *Thing, right *Thing) *Thing { return DoArithDyadic(left, right, ModOp) }
func DoEq(left *Thing, right *Thing) *Thing    { return DoArithDyadic(left, right, EqOp) }
func DoNeq(left *Thing, right *Thing) *Thing   { return DoArithDyadic(left, right, NeqOp) }
func DoLt(left *Thing, right *Thing) *Thing    { return DoArithDyadic(left, right, LtOp) }
func DoGt(left *Thing, right *Thing) *Thing    { return DoArithDyadic(left, right, GtOp) }
func DoLe(left *Thing, right *Thing) *Thing    { return DoArithDyadic(left, right, LeOp) }
func DoGe(left *Thing, right *Thing) *Thing    { return DoArithDyadic(left, right, GeOp) }

func DyadicReduce(left *Thing, right *Thing) *Thing {
	if left.Values.Len == 0 {
		panic("reduce: empty function name")
	}

	var buf [64]byte
	n := left.Values.Len
	if n > 63 {
		n = 63
	}
	for i := word(0); i < n; i++ {
		buf[i] = byte(PtrToInt(left.Values.Get(i)))
	}
	var s string
	s.Base = word(&buf[0])
	s.Len = n
	s.Cap = n
	name := Strings.Intern(s)

	var builtinFn DyadicFn
	var userFn *UserFunction

	fw, ok := DyadicOps.Lookup(name)
	if ok != 0 {
		builtinFn = DyadicFn(fw)
	} else {
		u, uok := UserDyadicOps.Lookup(name)
		if uok != 0 {
			userFn = u
		} else {
			panic("reduce: unknown dyadic function")
		}
	}

	if right.Dimensions.Len == 0 {
		return right
	}

	lastDimIdx := right.Dimensions.Len - 1
	innerLen := right.Dimensions.Get(lastDimIdx)
	if innerLen == 0 {
		panic("reduce: cannot reduce empty dimension")
	}

	outerLen := word(1)
	for i := word(0); i < lastDimIdx; i++ {
		outerLen = outerLen * right.Dimensions.Get(i)
	}

	result := NewThing()
	for i := word(0); i < lastDimIdx; i++ {
		result.Dimensions.Append(right.Dimensions.Get(i))
	}

	for o := word(0); o < outerLen; o++ {
		offset := o * innerLen
		acc := MakeScalar(PtrToInt(right.Values.Get(offset + innerLen - 1)))
		for i := innerLen - 1; i > 0; i-- {
			idx := i - 1
			item := MakeScalar(PtrToInt(right.Values.Get(offset + idx)))
			if ok != 0 {
				acc = builtinFn(item, acc)
			} else {
				acc = EvalUser(userFn, item, acc)
			}
		}
		result.Values.Append(acc.Values.Get(0))
	}
	return result
}

func DyadicTable(left *Thing, right *Thing) *Thing {
	if left.Values.Len == 0 {
		panic("table: empty function name")
	}

	var buf [64]byte
	n := left.Values.Len
	if n > 63 {
		n = 63
	}
	for i := word(0); i < n; i++ {
		buf[i] = byte(PtrToInt(left.Values.Get(i)))
	}
	var s string
	s.Base = word(&buf[0])
	s.Len = n
	s.Cap = n
	name := Strings.Intern(s)

	var builtinFn DyadicFn
	var userFn *UserFunction

	fw, ok := DyadicOps.Lookup(name)
	if ok != 0 {
		builtinFn = DyadicFn(fw)
	} else {
		u, uok := UserDyadicOps.Lookup(name)
		if uok != 0 {
			userFn = u
		} else {
			panic("table: unknown dyadic function")
		}
	}

	result := NewThing()
	for i := word(0); i < right.Dimensions.Len; i++ {
		result.Dimensions.Append(right.Dimensions.Get(i))
	}
	for i := word(0); i < right.Dimensions.Len; i++ {
		result.Dimensions.Append(right.Dimensions.Get(i))
	}

	for i := word(0); i < right.Values.Len; i++ {
		itemA := MakeScalar(PtrToInt(right.Values.Get(i)))
		for j := word(0); j < right.Values.Len; j++ {
			itemB := MakeScalar(PtrToInt(right.Values.Get(j)))
			var res *Thing
			if ok != 0 {
				res = builtinFn(itemA, itemB)
			} else {
				res = EvalUser(userFn, itemA, itemB)
			}
			result.Values.Append(res.Values.Get(0))
		}
	}
	return result
}

func DyadicCompress(left *Thing, right *Thing) *Thing {
	innerLen := word(1)
	lastDimIdx := word(0)
	outerLen := word(1)

	if right.Dimensions.Len > 0 {
		lastDimIdx = right.Dimensions.Len - 1
		innerLen = right.Dimensions.Get(lastDimIdx)
		for i := word(0); i < lastDimIdx; i++ {
			outerLen = outerLen * right.Dimensions.Get(i)
		}
	}

	if left.Values.Len != innerLen {
		panic("compress: length mismatch")
	}

	keepCount := word(0)
	for i := word(0); i < innerLen; i++ {
		if PtrToInt(left.Values.Get(i)) != 0 {
			keepCount++
		}
	}

	result := NewThing()
	for i := word(0); i < right.Dimensions.Len; i++ {
		if i == lastDimIdx {
			result.Dimensions.Append(keepCount)
		} else {
			result.Dimensions.Append(right.Dimensions.Get(i))
		}
	}
	if right.Dimensions.Len == 0 {
		result.Dimensions.Append(keepCount)
	}

	for o := word(0); o < outerLen; o++ {
		offset := o * innerLen
		for i := word(0); i < innerLen; i++ {
			if PtrToInt(left.Values.Get(i)) != 0 {
				result.Values.Append(right.Values.Get(offset + i))
			}
		}
	}

	return result
}

func DyadicExpand(left *Thing, right *Thing) *Thing {
	innerLen := word(1)
	lastDimIdx := word(0)
	outerLen := word(1)

	if right.Dimensions.Len > 0 {
		lastDimIdx = right.Dimensions.Len - 1
		innerLen = right.Dimensions.Get(lastDimIdx)
		for i := word(0); i < lastDimIdx; i++ {
			outerLen = outerLen * right.Dimensions.Get(i)
		}
	}

	keepCount := word(0)
	for i := word(0); i < left.Values.Len; i++ {
		if PtrToInt(left.Values.Get(i)) != 0 {
			keepCount++
		}
	}

	if keepCount != innerLen {
		panic("expand: length mismatch")
	}

	result := NewThing()
	for i := word(0); i < right.Dimensions.Len; i++ {
		if i == lastDimIdx {
			result.Dimensions.Append(left.Values.Len)
		} else {
			result.Dimensions.Append(right.Dimensions.Get(i))
		}
	}
	if right.Dimensions.Len == 0 {
		result.Dimensions.Append(left.Values.Len)
	}

	for o := word(0); o < outerLen; o++ {
		offset := o * innerLen
		srcIdx := word(0)
		for i := word(0); i < left.Values.Len; i++ {
			if PtrToInt(left.Values.Get(i)) != 0 {
				result.Values.Append(right.Values.Get(offset + srcIdx))
				srcIdx++
			} else {
				result.Values.Append(IntToPtr(0))
			}
		}
	}

	return result
}

// ===== Initialization =====

func init() {
	MonadicOps.Insert(Strings.Intern("iota"), word(DoIota))
	MonadicOps.Insert(Strings.Intern("rho"), word(DoRhoMonadic))
	MonadicOps.Insert(Strings.Intern("neg"), word(DoNeg))

	DyadicOps.Insert(Strings.Intern("rho"), word(DoRhoDyadic))
	DyadicOps.Insert(Strings.Intern("add"), word(DoAdd))
	DyadicOps.Insert(Strings.Intern("sub"), word(DoSub))
	DyadicOps.Insert(Strings.Intern("mul"), word(DoMulDy))
	DyadicOps.Insert(Strings.Intern("div"), word(DoDivDy))
	DyadicOps.Insert(Strings.Intern("mod"), word(DoModDy))
	DyadicOps.Insert(Strings.Intern("reduce"), word(DyadicReduce))
	DyadicOps.Insert(Strings.Intern("table"), word(DyadicTable))
	DyadicOps.Insert(Strings.Intern("compress"), word(DyadicCompress))
	DyadicOps.Insert(Strings.Intern("expand"), word(DyadicExpand))

	// Symbol aliases
	MonadicOps.Insert(Strings.Intern("-"), word(DoNeg))
	DyadicOps.Insert(Strings.Intern("+"), word(DoAdd))
	DyadicOps.Insert(Strings.Intern("-"), word(DoSub))
	DyadicOps.Insert(Strings.Intern("*"), word(DoMulDy))
	DyadicOps.Insert(Strings.Intern("=="), word(DoEq))
	DyadicOps.Insert(Strings.Intern("!="), word(DoNeq))
	DyadicOps.Insert(Strings.Intern("<"), word(DoLt))
	DyadicOps.Insert(Strings.Intern(">"), word(DoGt))
	DyadicOps.Insert(Strings.Intern("<="), word(DoLe))
	DyadicOps.Insert(Strings.Intern(">="), word(DoGe))
}

// ===== Pretty Printer =====

func PrintThing(t *Thing) {
	if word(t) == 0 {
		PutStr("nil\n")
		return
	}

	if t.Dimensions.Len == 0 {
		// Scalar
		PutInt(PtrToInt(t.Values.Get(0)))
		putchar('\n')
		return
	}

	// Compute max width for column alignment
	maxW := word(1)
	for i := range t.Values.Len {
		w := IntWidth(PtrToInt(t.Values.Get(i)))
		if w > maxW {
			maxW = w
		}
	}

	if t.Dimensions.Len == 1 {
		// Vector
		for i := range t.Values.Len {
			if i > 0 {
				putchar(' ')
			}
			PutIntPadded(PtrToInt(t.Values.Get(i)), maxW)
		}
		putchar('\n')
		return
	}

	if t.Dimensions.Len == 2 {
		// Matrix: rows x cols
		rows := t.Dimensions.Get(0)
		cols := t.Dimensions.Get(1)
		for r := range rows {
			for c := range cols {
				if c > 0 {
					putchar(' ')
				}
				PutIntPadded(PtrToInt(t.Values.Get(r*cols+c)), maxW)
			}
			putchar('\n')
		}
		return
	}

	// Higher rank: print flat with rank annotation
	PutStr("[rank ")
	PutInt(int(t.Dimensions.Len))
	PutStr("] ")
	for i := range t.Values.Len {
		if i > 0 {
			putchar(' ')
		}
		PutInt(PtrToInt(t.Values.Get(i)))
	}
	putchar('\n')
}

// ===== Test Helper =====

func TestEval(input *byte) *Thing {
	// Copy null-terminated input into LineBuf for the tokenizer
	LineLen = 0
	s := input
	for *s != 0 {
		LineBuf[LineLen] = *s
		LineLen++
		s = (*byte)(word(s) + 1)
	}
	Tokenize()
	EvalPos = 0
	if NumTokens == 0 {
		WasAssign = 0
		return (*Thing)(0)
	}
	var result *Thing
	result = EvalStatementsUntil(0, 0)
	return result
}

// ===== Tests =====

func RunTests() {
	PutStr("=== APL Tests ===\n")

	PutStr("iota 5 => ")
	PrintThing(TestEval("iota 5"))

	PutStr("3 3 rho iota 9 =>\n")
	PrintThing(TestEval("3 3 rho iota 9"))

	PutStr("2 3 rho 1 2 3 =>\n")
	PrintThing(TestEval("2 3 rho 1 2 3"))

	TestEval("Vec <- iota 4")
	PutStr("Vec <- iota 4\n")
	PutStr("Vec => ")
	PrintThing(TestEval("Vec"))

	PutStr("rho Vec => ")
	PrintThing(TestEval("rho Vec"))

	TestEval("A <- iota 3")
	PutStr("A <- iota 3\n")
	PutStr("A add A => ")
	PrintThing(TestEval("A add A"))

	PutStr("2 add 3 => ")
	PrintThing(TestEval("2 add 3"))

	PutStr("neg iota 4 => ")
	PrintThing(TestEval("neg iota 4"))

	PutStr("2 3 rho iota 6 =>\n")
	PrintThing(TestEval("2 3 rho iota 6"))

	TestEval("M <- 2 3 rho iota 6")
	PutStr("M <- 2 3 rho iota 6\n")
	PutStr("rho M => ")
	PrintThing(TestEval("rho M"))

	PutStr("10 mul iota 5 => ")
	PrintThing(TestEval("10 mul iota 5"))

	// Parenthesized subexpressions
	PutStr("(2 add 3) mul 4 => ")
	PrintThing(TestEval("(2 add 3) mul 4"))

	PutStr("(iota 3) add (iota 3) => ")
	PrintThing(TestEval("(iota 3) add (iota 3)"))

	// Symbol operators
	PutStr("2 + 3 => ")
	PrintThing(TestEval("2 + 3"))

	PutStr("10 - 3 => ")
	PrintThing(TestEval("10 - 3"))

	PutStr("4 * 5 => ")
	PrintThing(TestEval("4 * 5"))

	PutStr("- iota 4 => ")
	PrintThing(TestEval("- iota 4"))

	PutStr("(2 + 3) * 4 => ")
	PrintThing(TestEval("(2 + 3) * 4"))

	PutStr("5 == 5 => ")
	PrintThing(TestEval("5 == 5"))

	PutStr("5 != 4 => ")
	PrintThing(TestEval("5 != 4"))

	PutStr("3 < 4 => ")
	PrintThing(TestEval("3 < 4"))

	PutStr("5 > 4 => ")
	PrintThing(TestEval("5 > 4"))

	PutStr("3 <= 3 => ")
	PrintThing(TestEval("3 <= 3"))

	PutStr("4 >= 5 => ")
	PrintThing(TestEval("4 >= 5"))

	TestEval("B = 7")
	PutStr("B = 7\n")
	PutStr("B => ")
	PrintThing(TestEval("B"))

	PutStr("A <- 10 ; A add 5 => ")
	PrintThing(TestEval("A <- 10 ; A add 5"))

	TestEval("<> double X { X - X ; X + X }")
	PutStr("<> double X { X - X ; X + X }\n")
	PutStr("double 10 => ")
	PrintThing(TestEval("double 10"))

	PutStr("( 1 ? 10 : 20 ) => ")
	PrintThing(TestEval("( 1 ? 10 : 20 )"))

	PutStr("( 0 ? 10 : 20 ) => ")
	PrintThing(TestEval("( 0 ? 10 : 20 )"))

	PutStr("A <- 0 ; ( 1 ? A <- 1 : A <- 2 ) ; A => ")
	PrintThing(TestEval("A <- 0 ; ( 1 ? A <- 1 : A <- 2 ) ; A"))

	PutStr("( 1 ? 5 ; 10 : 15 ; 20 ) => ")
	PrintThing(TestEval("( 1 ? 5 ; 10 : 15 ; 20 )"))

	TestEval("<> A plus B ; M { M = A add B ; M }")
	PutStr("<> A plus B ; M { M = A add B ; M }\n")
	PutStr("10 plus 20 => ")
	PrintThing(TestEval("10 plus 20"))

	TestEval("<> |^| N { N < 0 }")
	PutStr("<> |^| N { N < 0 }\n")
	PutStr("|^| 5 - iota 10 => ")
	PrintThing(TestEval("|^| 5 - iota 10"))

	PutStr("\"add\" reduce iota 10 => ")
	PrintThing(TestEval("\"add\" reduce iota 10"))

	TestEval("M <- 2 3 rho iota 6")
	PutStr("M <- 2 3 rho iota 6\n")
	PutStr("\"add\" reduce M =>\n")
	PrintThing(TestEval("\"add\" reduce M"))

	PutStr("\"sub\" reduce 1 2 3 => ")
	PrintThing(TestEval("\"sub\" reduce 1 2 3"))

	TestEval("<> X custom Y { X mul Y }")
	PutStr("\"custom\" reduce 1 2 3 4 => ")
	PrintThing(TestEval("\"custom\" reduce 1 2 3 4"))

	PutStr("\"mul\" table 1 2 3 =>\n")
	PrintThing(TestEval("\"mul\" table 1 2 3"))

	PutStr("1 0 1 compress 10 20 30 => ")
	PrintThing(TestEval("1 0 1 compress 10 20 30"))

	PutStr("1 0 1 expand 10 30 => ")
	PrintThing(TestEval("1 0 1 expand 10 30"))

	PrintThing(TestEval(" \"Hello\" "))

	PutStr("=== Tests Done ===\n")
}

// ===== Main =====

func EvalLine() {
	defer func() {
		r := recover()
		if r != nil {
			PutStr("ERROR: ")
			PutStr(r)
			putchar('\n')
		}
	}()

	Tokenize()
	if NumTokens == 0 {
		return
	}
	EvalPos = 0
	var result *Thing
	result = EvalStatementsUntil(0, 0)
	if word(result) != 0 && WasAssign == 0 {
		PrintThing(result)
		Vars.Insert("_", result)
	}
}

func main() {
	for {
		PutStr("      ")
		ok := ReadLine()
		if ok == 0 {
			PutStr(" [EOF]")
			break
		}
		if LineLen == 0 {
			PutStr(" [BYE]\n")
			break // continue
		}
		if LineBuf[0] == ')' {
			cmd := byte(' ')
			if LineLen > 1 {
				cmd = LineBuf[1]
			}
			if cmd == 'v' {
				PutStr("Variables:\n  ")
				keys := Vars.Keys()
				sort.QuickSort[string](keys, CmpString)
				for i := range keys.Len {
					PutStr(keys.Get(i))
					putchar(' ')
				}
				putchar('\n')
			} else if cmd == 'm' {
				PutStr("Built-in Monadic Functions:\n  ")
				keys := MonadicOps.Keys()
				sort.QuickSort[string](keys, CmpString)
				for i := range keys.Len {
					PutStr(keys.Get(i))
					putchar(' ')
				}
				putchar('\n')
				PutStr("User Monadic Functions:\n  ")
				keys = UserMonadicOps.Keys()
				sort.QuickSort[string](keys, CmpString)
				for i := range keys.Len {
					PutStr(keys.Get(i))
					putchar(' ')
				}
				putchar('\n')
			} else if cmd == 'd' {
				PutStr("Built-in Dyadic Functions:\n  ")
				keys := DyadicOps.Keys()
				sort.QuickSort[string](keys, CmpString)
				for i := range keys.Len {
					PutStr(keys.Get(i))
					putchar(' ')
				}
				putchar('\n')
				PutStr("User Dyadic Functions:\n  ")
				keys = UserDyadicOps.Keys()
				sort.QuickSort[string](keys, CmpString)
				for i := range keys.Len {
					PutStr(keys.Get(i))
					putchar(' ')
				}
				putchar('\n')
			} else {
				PutStr("Commands:\n  )h  help\n  )v  variables\n  )m  monadic functions\n  )d  dyadic functions\n")
			}
			continue
		}
		EvalLine()
	}
	putchar('\n')
}
